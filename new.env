<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
import { getAuth, GoogleAuthProvider, signInWithPopup, signOut, onAuthStateChanged } 
from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";

const firebaseConfig = {
  apiKey: "AIzaSyCs_fw5VuUw70LQOVijRuvU1oDvRreDEcw",
  authDomain: "volleyball-team-maker.firebaseapp.com",
  projectId: "volleyball-team-maker",
  storageBucket: "volleyball-team-maker.firebasestorage.app",
  messagingSenderId: "279938274944",
  appId: "1:279938274944:web:649b97eba29b0f32983865",
  measurementId: "G-9BHZTQR13C"
};

const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const provider = new GoogleAuthProvider();

window.login = function () {
  signInWithPopup(auth, provider)
    .then(result => {
      console.log("Logged in:", result.user.uid);
    })
    .catch(error => console.error(error));
};

window.logout = function () {
  signOut(auth);
};

onAuthStateChanged(auth, (user) => {
  if (user) {
    console.log("User ID:", user.uid);
  } else {
    console.log("Logged out");
  }
});
</script>
